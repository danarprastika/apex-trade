# Environment
QUANTX_ENVIRONMENT=development
QUANTX_LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://quantx:quantx@localhost:5432/quantx

# Redis
REDIS_URL=redis://localhost:6379/0

# Exchange (testnet)
EXCHANGE_BINANCE_API_KEY=your_testnet_api_key
EXCHANGE_BINANCE_API_SECRET=your_testnet_api_secret
EXCHANGE_SANDBOX=true

# AI
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USERS=123456789

# Security
SECRET_KEY=generate_random_secret_key
