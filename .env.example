# Application
QUANTX_ENV=local
QUANTX_DEBUG=true
QUANTX_LOG_LEVEL=DEBUG
QUANTX_SECRET_KEY=change-me-in-production-64-char-min

# Database
DATABASE_URL=postgresql+asyncpg://quantx:quantx@localhost:5432/quantx
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Cache
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# AI Providers
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=openrouter

# Exchanges
EXCHANGE_BINANCE_API_KEY=
EXCHANGE_BINANCE_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Feature Flags
AI_STRATEGIES_ENABLED=false
BACKTESTING_ENABLED=false
PAPER_TRADING_MODE=true
NOTIFICATIONS_ENABLED=false
